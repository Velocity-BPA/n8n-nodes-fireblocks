{
  "name": "n8n-nodes-fireblocks",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Fireblocks institutional digital asset custody platform providing 15 resources and 100+ operations for vault management, transactions, staking, NFTs, smart contracts, and more.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-fireblocks.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-fireblocks#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-fireblocks/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "fireblocks",
    "custody",
    "digital-assets",
    "cryptocurrency",
    "mpc-wallet",
    "treasury",
    "defi",
    "staking",
    "nft",
    "smart-contracts",
    "institutional",
    "blockchain"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/FireblocksApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Fireblocks/Fireblocks.node.js",
      "dist/nodes/Fireblocks/FireblocksTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.1",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}